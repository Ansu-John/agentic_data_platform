{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "TerraformStateManagement",
            "Effect": "Allow",
            "Action": [
                "s3:ListBucket",
                "s3:GetObject",
                "s3:PutObject",
                "s3:DeleteObject",
                "dynamodb:GetItem",
                "dynamodb:PutItem",
                "dynamodb:DeleteItem"
            ],
            "Resource": [
                "arn:aws:s3:::dataplatform-dev-tfstate-bucket",
                "arn:aws:s3:::dataplatform-dev-tfstate-bucket/*",
                "arn:aws:dynamodb:*:*:table/terraform-state-lock"
            ]
        },
        {
            "Sid": "SSM",
            "Effect": "Allow",
            "Action": [
                "ssm:*"
            ],
            "Resource": [
                "arn:aws:ssm:*:*:parameter/dev/*",
                "arn:aws:ssm:us-east-1:932021957888:parameter/dev/core-static/*"
            ]
        },
        {
            "Sid": "ECRGetAuthToken",
            "Effect": "Allow",
            "Action": [
                "ecr:GetAuthorizationToken"
            ],
            "Resource": "*"
        },
        {
            "Sid": "ECRRepositoryManagement",
            "Effect": "Allow",
            "Action": [
                "ecr:BatchCheckLayerAvailability",
                "ecr:GetDownloadUrlForLayer",
                "ecr:GetRepositoryPolicy",
                "ecr:DescribeRepositories",
                "ecr:ListImages",
                "ecr:DescribeImages",
                "ecr:BatchGetImage",
                "ecr:InitiateLayerUpload",
                "ecr:UploadLayerPart",
                "ecr:CompleteLayerUpload",
                "ecr:PutImage",
                "ecr:CreateRepository",
                "ecr:DeleteRepository",
                "ecr:TagResource",
                "ecr:ListTagsForResource",
                "ecr:PutLifecyclePolicy",
                "ecr:SetRepositoryPolicy",
                "ecr:GetLifecyclePolicy",
                "ecr:DeleteLifecyclePolicy",
                "ecr:DeleteRepositoryPolicy"
            ],
            "Resource": "arn:aws:ecr:us-east-1:932021957888:repository/ai-catalog-agent"
        },
        {
            "Sid": "InfrastructureProvisioning",
            "Effect": "Allow",
            "Action": [
                "s3:*",
                "ec2:*",
                "ecs:*",
                "emr-serverless:*",
                "rds:*",
                "elasticloadbalancing:*",
                "application-autoscaling:*",
                "logs:*",
                "xray:*",
                "secretsmanager:*",
                "sns:*",
                "cloudwatch:*",
                "events:*"
            ],
            "Resource": "*",
            "Condition": {
                "StringEquals": {
                    "aws:RequestedRegion": [
                        "us-east-1"
                    ]
                }
            }
        },
        {
            "Sid": "IAMRoleAndPolicyManagement",
            "Effect": "Allow",
            "Action": [
                "iam:CreateRole",
                "iam:DeleteRole",
                "iam:GetRole",
                "iam:UpdateRole",
                "iam:AttachRolePolicy",
                "iam:DetachRolePolicy",
                "iam:PutRolePolicy",
                "iam:GetRolePolicy",
                "iam:DeleteRolePolicy",
                "iam:ListRolePolicies",
                "iam:CreatePolicy",
                "iam:CreatePolicyVersion",
                "iam:DeletePolicy",
                "iam:GetPolicy",
                "iam:GetPolicyVersion",
                "iam:ListAttachedRolePolicies",
                "iam:PassRole",
                "iam:TagPolicy",
                "iam:TagRole"
            ],
            "Resource": [
                "arn:aws:iam::*:role/ai-catalog-*",
                "arn:aws:iam::*:role/dev-*",
                "arn:aws:iam::*:policy/ai-catalog-*",
                "arn:aws:iam::*:policy/dev-*",
                "arn:aws:iam::*:role/github-actions-terraform-role",
                "arn:aws:iam::*:role/aws-service-role/*"
            ]
        },
        {
            "Sid": "ServiceLinkedRoles",
            "Effect": "Allow",
            "Action": [
                "iam:CreateServiceLinkedRole",
                "iam:DeleteServiceLinkedRole",
                "iam:GetServiceLinkedRoleDeletionStatus"
            ],
            "Resource": "arn:aws:iam::*:role/aws-service-role/*"
        },
        {
            "Sid": "DenyDestructiveActionsOnCoreState",
            "Effect": "Deny",
            "Action": [
                "s3:DeleteBucket",
                "dynamodb:DeleteTable"
            ],
            "Resource": [
                "arn:aws:s3:::dataplatform-dev-tfstate-bucket",
                "arn:aws:s3:::terraform-state-lock"
            ]
        },
        {
            "Sid": "GlobalReadActions",
            "Effect": "Allow",
            "Action": [
                "ec2:DescribeVpcs",
                "ec2:DescribeSubnets",
                "ec2:DescribeSecurityGroups",
                "ecs:DescribeClusters",
                "ecs:DescribeServices",
                "rds:DescribeDBInstances",
                "rds:DescribeDBClusters",
                "ssm:DescribeParameters"
            ],
            "Resource": "*"
        },
        {
            "Sid": "KMSManagement",
            "Effect": "Allow",
            "Action": [
                "kms:DescribeKey",
                "kms:CreateGrant",
                "kms:RetireGrant",
                "kms:ListGrants",
                "kms:GenerateDataKey*",
                "kms:Decrypt"
            ],
            "Resource": "arn:aws:kms:us-east-1:*:key/*"
        }
    ]
}